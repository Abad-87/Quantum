# .env.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values for local development.
# NEVER commit .env to GitHub — it contains secrets!
# ─────────────────────────────────────────────────────────────────────────────

# MongoDB connection string (from MongoDB Atlas → Connect → Drivers)
# Leave blank to use JSON file fallback (predictions.json)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/quantum?retryWrites=true&w=majority

# Environment tag (development | production)
ENVIRONMENT=development

# Log level (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO
